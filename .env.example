# Core runtime
NODE_ENV=development
ENGINE_PORT=8000
ENGINE_URL=http://localhost:8000
APP_ORIGIN=http://localhost:3000

# Datastores
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wtd
REDIS_URL=redis://localhost:6379

# App security/auth
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SECRETS_ENCRYPTION_KEY=base64_or_hex_32byte_key

# Shared cache + distributed limiter (REST Redis adapters)
RATE_LIMIT_REDIS_REST_URL=
RATE_LIMIT_REDIS_REST_TOKEN=
RATE_LIMIT_REDIS_PREFIX=wtd:rl
SHARED_CACHE_REDIS_REST_URL=
SHARED_CACHE_REDIS_REST_TOKEN=
SHARED_CACHE_REDIS_PREFIX=wtd:cache

# Abuse protection
TURNSTILE_SECRET_KEY=
TURNSTILE_FAIL_OPEN=false

# External market data keys
COINGECKO_API_KEY=
COINALYZE_API_KEY=
COINMARKETCAP_API_KEY=
CRYPTOQUANT_API_KEY=
ETHERSCAN_API_KEY=

# Optional telemetry/alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

