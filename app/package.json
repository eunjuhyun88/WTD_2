    "mk:lookup": "cd memory && memkraft lookup --brain-first",
    "mk:dream": "cd memory && memkraft dream",
    "mk:dream:dry": "cd memory && memkraft dream --dry-run",
    "mk:track": "cd memory && memkraft track",
    "mk:update": "cd memory && memkraft update",
    "mk:query": "cd memory && memkraft query",
    "mk:brief": "cd memory && memkraft brief",
    "mk:log": "cd memory && memkraft log",
    "mk:loops": "cd memory && memkraft open-loops",
    "mk:health": "cd memory && memkraft dream --dry-run && echo 'Memory health OK'"
