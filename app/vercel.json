{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "sveltekit",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": ".vercel/output",
  "devCommand": "npm run dev",
  "regions": [
    "sin1"
  ],
  "git": {
    "deploymentEnabled": {
      "main": false,
      "master": false,
      "release": true,
      "claude/**": false,
      "claude-*": false,
      "codex/**": false,
      "codex-*": false,
      "feat/**": false,
      "fix/**": false,
      "chore/**": false,
      "docs/**": false
    }
  },
  "github": {
    "silent": true,
    "autoAlias": false
  },
  "ignoreCommand": "\\! git log -1 --pretty=%B | grep -qF \"[deploy]\""
}