# ═══════════════════════════════════════════════════════════════
# WTD / CHATBATTLE — Environment template
# ═══════════════════════════════════════════════════════════════
#
# SECURITY:
#  - This file IS committed to git. NEVER paste real keys here.
#  - Real keys live in `.env` (gitignored) or in Vercel via
#    `vercel env add <NAME> production --sensitive` (encrypted +
#    masked in dashboard logs).
#  - The runtime safeguard `isUsableApiKey()` rejects any value
#    containing `your_`, `your-`, `placeholder`, `changeme`,
#    `example`, `dummy`, or `<` — so accidentally leaving these
#    placeholders in `.env` will mark the provider as unavailable
#    instead of failing on first request.
#  - All `.env*` files except `.env.example` and `.env.test` are
#    gitignored (see top of `.gitignore`).
#
# ROTATION POOL CONVENTION:
#  - `XXX_API_KEY`   = primary key (singular)
#  - `XXX_API_KEYS`  = optional comma-separated rotation pool
#  - On 429 (rate limit) or 401/403 (revoked), the runtime
#    automatically rotates to the next key in the pool. Pool order
#    is in-memory only and resets on cold start.
#  - To use a single key, leave `XXX_API_KEYS` empty or absent.
#
# ═══════════════════════════════════════════════════════════════

# ─── 1. Database + Auth (REQUIRED) ─────────────────────────────
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
PGSSL_DISABLE=false
PGSSL_INSECURE_SKIP_VERIFY=false
SECRETS_ENCRYPTION_KEY=base64_or_hex_32byte_key

# ─── 2. LLM — Primary fast path (rotation-capable) ─────────────
# Cerebras: blazing-fast, free tier; primary fallback after Groq.
CEREBRAS_API_KEY=csk-your_primary_cerebras_key
CEREBRAS_API_KEYS=csk-your_secondary_cerebras_key,csk-your_tertiary_cerebras_key
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# Groq: high TPS, generous free tier. Heavy rotation pool recommended.
GROQ_API_KEY=gsk_your_primary_groq_key
GROQ_API_KEYS=gsk_secondary,gsk_tertiary,gsk_quaternary

# HuggingFace router (OpenAI-compatible). Rotation pool recommended.
HF_TOKEN=hf_your_primary_hf_token
HF_TOKENS=hf_secondary,hf_tertiary
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# ─── 3. LLM — Fallback providers (rotation-capable) ────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEYS=

DEEPSEEK_API_KEY=sk-your_deepseek_api_key
DEEPSEEK_API_KEYS=

QWEN_API_KEY=sk-your_qwen_api_key
QWEN_API_KEYS=

GROK_API_KEY=xai-your_grok_api_key
GROK_API_KEYS=

KIMI_API_KEY=sk-your_kimi_api_key
KIMI_API_KEYS=

MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_API_KEYS=
MISTRAL_MODEL=mistral-medium-latest

# OpenRouter: aggregator (free tier ~50 req/day). Last-resort fallback.
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=WTD

# ─── 4. LLM — Local (no API key, optional) ─────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

# ─── 5. Crypto data providers ──────────────────────────────────
COINGECKO_API_KEY=CG-your_coingecko_api_key
COINALYZE_API_KEY=your_coinalyze_api_key
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
CRYPTOQUANT_API_KEY=your_cryptoquant_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
DUNE_API_KEY=your_dune_api_key
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key
ALLIUM_API_KEY=your_allium_api_key
SANTIMENT_API_KEY=your_santiment_api_key
LUNARCRUSH_API_KEY=your_lunarcrush_api_key
FRED_API_KEY=your_fred_api_key

# ─── 6. Wallet / Chain (Arbitrum default) ──────────────────────
PUBLIC_EVM_CHAIN_ID=42161
PUBLIC_EVM_RPC_URL=https://arb1.arbitrum.io/rpc
PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ─── 7. Distributed rate limit (Redis REST, optional) ──────────
RATE_LIMIT_REDIS_REST_URL=
RATE_LIMIT_REDIS_REST_TOKEN=
RATE_LIMIT_REDIS_PREFIX=wtd:rl
RATE_LIMIT_REDIS_TIMEOUT_MS=3000

# ─── 8. Abuse / Bot protection ─────────────────────────────────
TURNSTILE_SECRET_KEY=
TURNSTILE_FAIL_OPEN=false
TURNSTILE_ALLOW_BYPASS=true
TURNSTILE_TIMEOUT_MS=4000
CF_THREAT_SCORE_ENFORCE=false
CF_THREAT_SCORE_BLOCK_THRESHOLD=30
SECURITY_BLOCKED_IPS=
SECURITY_TRUST_PROXY_HEADERS=
SECURITY_ORIGIN_GUARD_ENABLED=true
SECURITY_ALLOWED_ORIGINS=
SECURITY_ALLOW_SESSION_MUTATION_WITHOUT_ORIGIN=false

# ─── 9. Notifications (optional) ───────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── 10. Python Engine ─────────────────────────────────────────
# URL of the FastAPI engine (uvicorn api.main:app --port 8000)
# Default: http://localhost:8000  (no trailing slash)
ENGINE_URL=http://localhost:8000
