{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(cd engine && python -m pytest*)",
      "Bash(npm --prefix app run check)",
      "Bash(npm --prefix app run build)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-pytest.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-commit.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-pytest.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-commit.sh"
          }
        ]
      }
    ]
  }
}
