#!/usr/bin/env bash
# pre-commit — agent ID 검증 + W-0274 optimistic concurrency 충돌 감지
#
# Install: git config core.hooksPath .githooks  (또는 app/scripts/dev/install-git-hooks.sh)
# Active path: REPO/.githooks/pre-commit
#
# 책임:
#   [1] state/current_agent.txt이 "unknown" 또는 빈값이면 commit 거절
#       - 메타/메모리/상태 sync staged-only 변경은 예외
#   [2] W-0274 conflict-detector: staged 파일이 다른 agent에게 claimed되어 있으면
#       commit 거절 (optimistic concurrency — CAS check)
#
# 배경 (PR #354):
#   A009~A016 8개 에이전트의 jsonl 11 entries가 silent loss됨.
#   원인: end.sh가 unknown agent를 허용 → per-agent 파일에 안 기록.
#   해결: commit 시점에 차단 → 자연히 start.sh 실행 강제됨.
#
# W-0274 추가 (Phase 4 Optimistic Concurrency):
#   multi-agent 환경에서 두 agent가 동시에 같은 파일을 수정하는 경우를 감지.
#   conflict-detector.mjs check-staged 호출 → 충돌 시 exit 1.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -z "${REPO_ROOT:-}" ] && exit 0

cd "$REPO_ROOT"

# state/current_agent.txt — main repo 공통 (git common dir 기준)
GIT_COMMON_DIR="$(git rev-parse --git-common-dir 2>/dev/null)"
MAIN_REPO="$(cd "$GIT_COMMON_DIR/.." && pwd)"
AGENT_FILE="$MAIN_REPO/state/current_agent.txt"

AGENT="unknown"
if [ -f "$AGENT_FILE" ]; then
  AGENT="$(tr -d '[:space:]' < "$AGENT_FILE" 2>/dev/null || echo unknown)"
  [ -z "$AGENT" ] && AGENT="unknown"
fi

# Agent 정상 → [2] W-0274 CAS check 실행
if [ "$AGENT" != "unknown" ] && [ -n "$AGENT" ]; then
  # W-0274: conflict-detector.mjs — staged 파일 claim 충돌 감지
  CONFLICT_DETECTOR="$REPO_ROOT/tools/conflict-detector.mjs"
  if [ -f "$CONFLICT_DETECTOR" ]; then
    # node 경로 탐색 (zprofile에 설치된 경우 PATH에 없을 수 있음)
    NODE_BIN="$(command -v node 2>/dev/null || \
                ls ~/.local/node-v*/bin/node 2>/dev/null | head -1 || \
                echo "")"
    if [ -n "$NODE_BIN" ]; then
      if ! "$NODE_BIN" "$CONFLICT_DETECTOR" check-staged --agent "$AGENT" 2>&1; then
        echo ""
        echo "❌ pre-commit blocked: W-0274 optimistic concurrency conflict"
        echo ""
        echo "Staged files conflict with another agent's claim."
        echo "See output above.  To bypass (if you're sure):"
        echo "  node tools/conflict-detector.mjs release --agent <owner>"
        echo "  # then retry the commit"
        echo ""
        exit 1
      fi
    fi
    # node not found → skip W-0274 check (soft degradation)
  fi

  # [3] W-1004 ownership check — 타인 소유 파일 staged 시 차단
  OWNERSHIP_CHECK="$REPO_ROOT/tools/check-ownership.mjs"
  if [ -f "$OWNERSHIP_CHECK" ] && [ -n "$NODE_BIN" ]; then
    OVERRIDE_FLAG=""
    echo "$*" | grep -q -- "--override-owner" && OVERRIDE_FLAG="--override-owner" || true
    if ! "$NODE_BIN" "$OWNERSHIP_CHECK" $OVERRIDE_FLAG 2>&1; then
      exit 1
    fi
  fi

  exit 0
fi

# Agent unknown → staged 파일 화이트리스트 체크
STAGED_FILES="$(git diff --cached --name-only 2>/dev/null || echo '')"

# 화이트리스트 (이 경로만 변경됐다면 unknown 허용):
#   memory/sessions/*, memory/decisions/*, memory/incidents/*, memory/MEMORY.md
#   state/*
#   .githooks/*  (hook 설치/수정 자체는 허용 — 무한 chicken-and-egg 방지)
ALL_WHITELISTED=1
HAS_FILES=0
while IFS= read -r f; do
  [ -z "$f" ] && continue
  HAS_FILES=1
  case "$f" in
    memory/sessions/*|memory/decisions/*|memory/incidents/*|memory/MEMORY.md)
      ;;
    state/*)
      ;;
    .githooks/*)
      ;;
    *)
      ALL_WHITELISTED=0
      ;;
  esac
done <<< "$STAGED_FILES"

if [ "$HAS_FILES" = "1" ] && [ "$ALL_WHITELISTED" = "1" ]; then
  exit 0
fi

# 거절
echo ""
echo "❌ pre-commit blocked: state/current_agent.txt = 'unknown'"
echo ""
echo "이 워크트리는 Agent ID가 없습니다. silent loss(PR #354 — A009~A016)"
echo "재발 방지를 위해 session boot 없이 commit이 거절됩니다."
echo ""
echo "해결:"
echo "  cd $MAIN_REPO"
echo "  ./tools/start.sh    # Agent ID 발번 + state 갱신"
echo ""
echo "긴급 우회 (메모리/상태/hook sync 외 path):"
echo "  echo 'A###' > $AGENT_FILE   # 직전 핸드오프 ID 사용"
echo ""
exit 1
